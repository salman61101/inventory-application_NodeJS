<!DOCTYPE html>
<html lang="en">
<%- include("partials/head", { title }) %>
<body>
    <div class="page-shell">
        <%- include("partials/nav") %>

        <main class="container">
            <section class="card form-card">
                <p class="eyebrow">Categories</p>
                <h1><%= title %></h1>

                <form action="<%= category ? '/categories/' + category.id + '/edit' : '/categories/new' %>" method="POST" class="stacked-form">
                    <label>
                        <span>Category Name</span>
                        <input type="text" name="name" required value="<%= category ? category.name : '' %>">
                    </label>

                    <label>
                        <span>Description</span>
                        <textarea name="description" rows="5" required><%= category ? category.description : '' %></textarea>
                    </label>

                    <div class="actions">
                        <a class="button secondary" href="/categories">Back</a>
                        <button class="button" type="submit"><%= category ? "Update Category" : "Add Category" %></button>
                    </div>
                </form>
            </section>
        </main>
    </div>
</body>
</html>