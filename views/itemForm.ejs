<!DOCTYPE html>
<html lang="en">
<%- include("partials/head", { title }) %>
<body>
    <div class="page-shell">
        <%- include("partials/nav") %>

        <main class="container">
            <section class="card form-card">
                <p class="eyebrow">Items</p>
                <h1><%= title %></h1>

                <% const selectedCategoryId = item ? String(item.category_id) : ""; %>

                <form action="<%= item ? '/items/' + item.id + '/edit' : '/items/new' %>" method="POST" class="stacked-form">
                    <label>
                        <span>Name</span>
                        <input type="text" name="name" required value="<%= item ? item.name : '' %>">
                    </label>

                    <label>
                        <span>Description</span>
                        <textarea name="description" rows="5" required><%= item ? item.description : '' %></textarea>
                    </label>

                    <div class="form-row">
                        <label>
                            <span>Price</span>
                            <input type="number" step="0.01" name="price" required value="<%= item ? item.price : '' %>">
                        </label>

                        <label>
                            <span>Quantity</span>
                            <input type="number" name="quantity" required value="<%= item ? item.quantity : '' %>">
                        </label>
                    </div>

                    <label>
                        <span>Category</span>
                        <select name="category_id" required>
                            <% categories.forEach(category => { %>
                                <option value="<%= category.id %>" <%= selectedCategoryId === String(category.id) ? "selected" : "" %>><%= category.name %></option>
                            <% }) %>
                        </select>
                    </label>

                    <div class="actions">
                        <a class="button secondary" href="/items">Back</a>
                        <button class="button" type="submit"><%= item ? "Update Item" : "Add Item" %></button>
                    </div>
                </form>
            </section>
        </main>
    </div>
</body>
</html>