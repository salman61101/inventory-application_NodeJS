<!DOCTYPE html>
<html lang="en">
<%- include("partials/head", { title }) %>
<body>
    <div class="page-shell">
        <%- include("partials/nav") %>

        <main class="container">
            <section class="card detail-card">
                <p class="eyebrow">Category Details</p>
                <h1><%= category.name %></h1>

                <div class="detail-list">
                    <div>
                        <span class="detail-label">Description</span>
                        <p><%= category.description %></p>
                    </div>
                </div>

                <div class="actions">
                    <a class="button secondary" href="/categories">Back</a>
                    <a class="button" href="/categories/<%= category.id %>/edit">Edit Category</a>
                    <a class="button danger" href="/categories/<%= category.id %>/delete">Delete Category</a>
                </div>
            </section>
        </main>
    </div>
</body>
</html>